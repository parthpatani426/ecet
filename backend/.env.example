# ============ Database ============
DATABASE_URL=postgresql://ecetx_user:ecetx_password@localhost:5432/ecetx_db

# ============ JWT & Security ============
SECRET_KEY=your-super-secret-key-change-this-in-production-at-least-32-chars
ALGORITHM=HS256

# ============ Email Configuration ============
# Choose ONE provider: SMTP (default), SendGrid, or Resend

# SMTP Configuration (Default)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# SendGrid API Key (Optional - comment out if using SMTP)
# SENDGRID_API_KEY=your-sendgrid-api-key

# Resend API Key (Optional - comment out if using SMTP)
# RESEND_API_KEY=your-resend-api-key

FROM_EMAIL=noreply@ecetx.com

# ============ Application Settings ============
ENVIRONMENT=development
FRONTEND_URL=http://localhost:8000

# ============ OTP Settings ============
OTP_EXPIRY_MINUTES=15
OTP_LENGTH=6

# ============ Token Expiry ============
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
